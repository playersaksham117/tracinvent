# ============================================
# BillEase SaaS - Environment Configuration
# ============================================

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="BillEase Suite"
NEXT_PUBLIC_APP_DESCRIPTION="All-in-One Business Management Platform"

# Currency & Localization
NEXT_PUBLIC_DEFAULT_CURRENCY=INR
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Kolkata
NEXT_PUBLIC_DEFAULT_COUNTRY=IN
NEXT_PUBLIC_DEFAULT_LOCALE=en-IN

# Features Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_BUDGETS=true
NEXT_PUBLIC_ENABLE_RECURRING=true
NEXT_PUBLIC_ENABLE_MULTI_CURRENCY=false
NEXT_PUBLIC_ENABLE_REPORTS=true

# Subscription & Billing (Stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-password
EMAIL_FROM=noreply@billease.com

# File Upload (Supabase Storage)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=attachments
NEXT_PUBLIC_MAX_FILE_SIZE=5242880

# Analytics & Monitoring (Optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
SENTRY_DSN=your-sentry-dsn

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Session Configuration
SESSION_SECRET=your-random-secret-min-32-chars
SESSION_MAX_AGE=604800

# Development
NODE_ENV=development
